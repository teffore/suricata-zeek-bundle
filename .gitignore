terraform/

# Private keys / secrets — never commit
*.pem
*.key
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
.env
.env.*

# Claude Code state
.claude/

# Local-only IAM helper — contains env-specific role-name assumptions,
# kept out of the repo so forks don't pick it up
update-iam-role.ps1

# Benchmark run outputs — timestamped per run, noisy in git. The .gitkeep
# keeps the directory tracked; baseline.json is explicitly committed when
# a new baseline is captured.
purple-agent/benchmarks/results/*.json
purple-agent/benchmarks/results/*.log
!purple-agent/benchmarks/baseline.json

