terraform/

# Private keys / secrets — never commit
*.pem
*.key
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
.env
.env.*

# Claude Code state
.claude/

# Local-only IAM helper — contains env-specific role-name assumptions,
# kept out of the repo so forks don't pick it up
update-iam-role.ps1

# Lab state — SSH private key + ephemeral AWS resource IDs. Must never be committed.
# Managed by lab-up.sh / lab-down.sh at repo root.
.lab-state
.lab-key
.lab-key.pub
.install-logs/

# Agent Orange per-run output directories — noisy in git. Each run is
# self-contained under agent-orange/runs/<ts>/. A baseline run can be
# committed by name (e.g., agent-orange/runs/baseline-YYYYMMDD/).
agent-orange/runs/*/
agent-orange/runs/index.json
agent-orange/runs/*.log
!agent-orange/runs/baseline-*/

# Python bytecode — agent-orange generates these during tests; never commit.
__pycache__/
*.pyc

# pytest-cov data files — local-only, regenerated each run.
.coverage
.coverage.*
htmlcov/

